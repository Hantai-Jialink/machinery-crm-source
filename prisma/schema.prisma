generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "rhel-openssl-1.0.x", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== 枚举定义 ====================

enum Role {
  SUPER_ADMIN
  SALES
  FOREIGN_TRADE
  WAREHOUSE
}

enum CustomerStatus {
  NEW_LEAD
  CONTACTED
  QUOTED
  NEGOTIATING
  WON
  LOST
  INACTIVE
}

enum CustomerType {
  NEW
  OLD
  AGENT
  END_USER
  DISTRIBUTOR
}

enum CustomerLevel {
  A
  B
  C
  D
}

enum FollowType {
  PHONE
  WECHAT
  EMAIL
  WHATSAPP
  VIDEO
  VISIT
  EXHIBITION
  OTHER
}

enum Language {
  ZH
  EN
  ES
  RU
}

enum ProductType {
  MAIN
  OPTIONAL
}

enum QuoteItemType {
  MAIN
  OPTIONAL
}

enum ContractItemType {
  MAIN
  OPTIONAL
}

enum PaymentStatus {
  UNPAID
  PARTIAL_PAID
  PAID
}

enum ContractStatus {
  DRAFT
  SIGNED
  CANCELLED
  COMPLETED
  ARCHIVED
}

enum ShipmentStatus {
  NOT_SHIPPED
  PARTIAL_SHIPPED
  SHIPPED
}

enum PaymentRecordStatus {
  ACTIVE
  VOIDED
}

enum ContractUnlockStatus {
  PENDING
  APPROVED
  REJECTED
  USED
}

// ==================== 用户模型 ====================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  region    String   @default("其他")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customers        Customer[]
  followRecords    FollowRecord[]
  auditLogs        AuditLog[]
  contracts        Contract[]       @relation("SalesUser")
  createdContracts Contract[]       @relation("ContractCreator")
  customerQuotes   CustomerQuote[]
  contractPayments ContractPayment[]
  shipments        Shipment[]
  operationLogs    OperationLog[]
  requestedUnlocks ContractUnlockRequest[] @relation("ContractUnlockRequester")
  approvedUnlocks  ContractUnlockRequest[] @relation("ContractUnlockApprover")

  @@map("users")
}

// ==================== 客户模型 ====================

model Customer {
  id             String         @id @default(uuid())
  companyName    String
  contactName    String
  phone          String?
  wechat         String?
  whatsapp       String?
  email          String?
  country        String?        @default("中国")
  province       String?
  city           String?
  region         String
  address        String?        @db.Text
  customerSource String
  customerType   CustomerType
  customerLevel  CustomerLevel
  status         CustomerStatus @default(NEW_LEAD)
  interestTags   Json           @default("[]")
  assignedUserId String?
  assignedUser   User?          @relation(fields: [assignedUserId], references: [id])
  remark         String?        @db.Text
  lastFollowDate DateTime?
  nextFollowDate DateTime?      @db.Date
  duplicateKey   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  followRecords  FollowRecord[]
  contracts      Contract[]
  customerQuotes CustomerQuote[]

  @@index([region])
  @@index([status])
  @@index([assignedUserId])
  @@index([nextFollowDate])
  @@index([deletedAt])
  @@map("customers")
}

// ==================== 跟进记录模型 ====================

model FollowRecord {
  id             String          @id @default(uuid())
  customerId     String
  customer       Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  followType     FollowType
  content        String          @db.Text
  result         String?         @db.Text
  nextFollowDate DateTime?       @db.Date
  newStatus      CustomerStatus?
  createdAt      DateTime        @default(now())

  @@index([customerId])
  @@index([userId])
  @@map("follow_records")
}

// ==================== 产品模型（主表） ====================

model Product {
  id           String   @id @default(uuid())
  model        String   @unique
  category     String
  productType  ProductType @default(MAIN)
  imageUrl     String?
  videoUrl     String?
  factoryPrice Decimal? @db.Decimal(12, 2)
  currency     String   @default("CNY")
  remark       String?  @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  translations   ProductTranslation[]
  contracts      Contract[]
  customerQuotes CustomerQuote[]
  quoteItems     CustomerQuoteItem[]
  contractItems  ContractItem[]

  @@map("products")
}

// ==================== 产品多语言资料模型 ====================

model ProductTranslation {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  language    Language
  name        String
  description String?  @db.Text
  specs       Json?
  pdfUrl      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, language])
  @@map("product_translations")
}

// ==================== 客户报价模型 ====================

model CustomerQuote {
  id                   String   @id @default(uuid())
  customerId           String
  customer             Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId            String
  product              Product  @relation(fields: [productId], references: [id])
  quotedPrice          Decimal  @db.Decimal(12, 2)
  factoryPriceSnapshot Decimal? @db.Decimal(12, 2)
  currency             String   @default("CNY")
  remark               String?  @db.Text
  createdById          String
  createdBy            User     @relation(fields: [createdById], references: [id])
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  items                CustomerQuoteItem[]
  sourceContract       Contract? @relation("QuoteSourceContract")

  @@index([customerId])
  @@index([productId])
  @@map("customer_quotes")
}

model CustomerQuoteItem {
  id                   String        @id @default(uuid())
  quoteId              String
  quote                CustomerQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId            String
  product              Product       @relation(fields: [productId], references: [id])
  itemType             QuoteItemType
  productNameSnapshot  String
  productModelSnapshot String
  factoryPriceSnapshot Decimal?      @db.Decimal(12, 2)
  quotedPrice          Decimal?      @db.Decimal(12, 2)
  quantity             Int           @default(1)
  sortOrder            Int           @default(0)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([quoteId])
  @@index([productId])
  @@map("customer_quote_items")
}

// ==================== 合同模型 ====================

model Contract {
  id             String         @id @default(uuid())
  contractNo     String         @unique
  signedDate     DateTime       @db.Date
  estimatedShipmentDate DateTime? @db.Date
  customerId     String
  customer       Customer       @relation(fields: [customerId], references: [id])
  salesUserId    String
  salesUser      User           @relation("SalesUser", fields: [salesUserId], references: [id])
  productId      String?
  product        Product?       @relation(fields: [productId], references: [id])
  sourceQuoteId  String?        @unique
  sourceQuote    CustomerQuote? @relation("QuoteSourceContract", fields: [sourceQuoteId], references: [id])
  equipmentName  String
  equipmentModel String
  amount         Decimal        @db.Decimal(12, 2)
  paidAmount     Decimal        @default(0) @db.Decimal(12, 2)
  unpaidAmount   Decimal?       @db.Decimal(12, 2)
  currency       String         @default("CNY")
  attachmentUrl  String?
  remark         String?        @db.Text
  paymentStatus  PaymentStatus  @default(UNPAID)
  contractStatus ContractStatus @default(SIGNED)
  editUnlockedUntil DateTime?
  editUnlockRequestId String?
  createdById    String
  createdBy      User           @relation("ContractCreator", fields: [createdById], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  payments ContractPayment[]
  shipments Shipment[]
  items     ContractItem[]
  unlockRequests ContractUnlockRequest[]

  @@index([customerId])
  @@index([salesUserId])
  @@index([paymentStatus])
  @@index([contractStatus])
  @@index([estimatedShipmentDate])
  @@index([deletedAt])
  @@map("contracts")
}

model ContractItem {
  id                   String           @id @default(uuid())
  contractId           String
  contract             Contract         @relation(fields: [contractId], references: [id], onDelete: Cascade)
  productId            String
  product              Product          @relation(fields: [productId], references: [id])
  itemType             ContractItemType
  productNameSnapshot  String
  productModelSnapshot String
  factoryPriceSnapshot Decimal?         @db.Decimal(12, 2)
  contractPrice        Decimal?         @db.Decimal(12, 2)
  quantity             Int              @default(1)
  sortOrder            Int              @default(0)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([contractId])
  @@index([productId])
  @@map("contract_items")
}

// ==================== 发货记录模型 ====================

model Shipment {
  id              String         @id @default(uuid())
  contractId      String
  contract        Contract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  shipmentDate    DateTime       @db.Date
  receivingAddress String        @db.Text
  driverPhone     String
  equipmentName   String
  quantity        Int
  shipmentStatus  ShipmentStatus @default(NOT_SHIPPED)
  deliveryNoteUrl String?
  shipmentPhotoUrl String?
  remark          String?        @db.Text
  createdById     String
  createdBy       User           @relation(fields: [createdById], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([contractId])
  @@index([shipmentStatus])
  @@index([shipmentDate])
  @@map("shipments")
}

// ==================== 合同回款记录模型 ====================

model ContractPayment {
  id            String   @id @default(uuid())
  contractId    String
  contract      Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  amount        Decimal  @db.Decimal(12, 2)
  paymentDate   DateTime @db.Date
  paymentMethod String?
  remark        String?  @db.Text
  status        PaymentRecordStatus @default(ACTIVE)
  createdById   String
  createdBy     User     @relation(fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([contractId])
  @@map("contract_payments")
}

model ContractUnlockRequest {
  id               String               @id @default(uuid())
  contractId       String
  contract         Contract             @relation(fields: [contractId], references: [id], onDelete: Cascade)
  requesterId      String
  requester        User                 @relation("ContractUnlockRequester", fields: [requesterId], references: [id])
  approverId       String?
  approver         User?                @relation("ContractUnlockApprover", fields: [approverId], references: [id])
  status           ContractUnlockStatus @default(PENDING)
  reason           String               @db.Text
  approvalRemark   String?              @db.Text
  createdAt        DateTime             @default(now())
  approvedAt       DateTime?
  rejectedAt       DateTime?
  usedAt           DateTime?
  updatedAt        DateTime             @updatedAt

  @@index([contractId])
  @@index([requesterId])
  @@index([approverId])
  @@index([status])
  @@map("contract_unlock_requests")
}

model OperationLog {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  action       String
  entityType   String
  entityId     String
  beforeData   Json?
  afterData    Json?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@map("operation_logs")
}

// ==================== 操作审计日志 ====================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityName String
  entityId   String?
  details    String?  @db.Text
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ==================== ERP 第 1 期：枚举 ====================

enum StockInType {
  PURCHASE
  RETURN
  INITIAL
  CHECK_IN
  OTHER
}

enum StockOutType {
  PRODUCTION
  CHECK_OUT
  OTHER
}

enum StockCheckStatus {
  DRAFT
  CHECKING
  DONE
}

enum StockMovementType {
  STOCK_IN
  STOCK_OUT
  CHECK_ADJUST
}

// ==================== ERP：仓库 ====================
// 注：createdById / productId 等指向 CRM 既有模型（User/Product）的字段
// 一律使用标量外键（不声明 @relation），以遵守「不改动 CRM 既有模型」约束。

model Warehouse {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  inventories Inventory[]
  stockIns    StockIn[]
  stockOuts   StockOut[]
  stockChecks StockCheck[]
  movements   StockMovement[]

  @@index([isActive])
  @@map("erp_warehouses")
}

// ==================== ERP：物料分类（树形） ====================

model MaterialCategory {
  id        String            @id @default(uuid())
  name      String
  code      String
  parentId  String?
  parent    MaterialCategory?  @relation("MaterialCategoryTree", fields: [parentId], references: [id])
  children  MaterialCategory[] @relation("MaterialCategoryTree")
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())

  materials Material[]

  @@index([parentId])
  @@map("erp_material_categories")
}

// ==================== ERP：物料主表 ====================

model Material {
  id            String           @id @default(uuid())
  code          String           @unique
  name          String
  categoryId    String
  category      MaterialCategory @relation(fields: [categoryId], references: [id])
  spec          String?
  materialType  String?
  drawingNo     String?
  unit          String           @default("件")
  standardPrice Decimal?         @db.Decimal(12, 2)
  safetyStock   Decimal?         @db.Decimal(10, 2)
  weight        Decimal?         @db.Decimal(10, 2)
  remark        String?          @db.Text
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?

  inventories     Inventory[]
  stockInItems    StockInItem[]
  stockOutItems   StockOutItem[]
  stockCheckItems StockCheckItem[]
  movements       StockMovement[]
  bomItems        BomItem[]

  @@index([categoryId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("erp_materials")
}

// ==================== ERP：库存台账 ====================

model Inventory {
  id          String    @id @default(uuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  materialId  String
  material    Material  @relation(fields: [materialId], references: [id])
  quantity    Decimal   @default(0) @db.Decimal(10, 2)
  totalAmount Decimal   @default(0) @db.Decimal(12, 2)
  avgPrice    Decimal?  @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([warehouseId, materialId])
  @@index([materialId])
  @@map("erp_inventories")
}

// ==================== ERP：入库单（头 + 明细） ====================

model StockIn {
  id          String      @id @default(uuid())
  batchNo     String      @unique
  warehouseId String
  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id])
  type        StockInType @default(PURCHASE)
  remark      String?     @db.Text
  createdById String
  createdAt   DateTime    @default(now())

  items StockInItem[]

  @@index([warehouseId])
  @@index([type])
  @@index([createdById])
  @@index([createdAt])
  @@map("erp_stock_ins")
}

model StockInItem {
  id         String   @id @default(uuid())
  stockInId  String
  stockIn    StockIn  @relation(fields: [stockInId], references: [id], onDelete: Cascade)
  materialId String
  material   Material @relation(fields: [materialId], references: [id])
  quantity   Decimal  @db.Decimal(10, 2)
  unitPrice  Decimal  @db.Decimal(12, 2)
  amount     Decimal  @db.Decimal(12, 2)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([stockInId])
  @@index([materialId])
  @@map("erp_stock_in_items")
}

// ==================== ERP：出库单（头 + 明细） ====================

model StockOut {
  id          String       @id @default(uuid())
  batchNo     String       @unique
  warehouseId String
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id])
  type        StockOutType @default(PRODUCTION)
  remark      String?      @db.Text
  createdById String
  createdAt   DateTime     @default(now())

  items StockOutItem[]

  @@index([warehouseId])
  @@index([type])
  @@index([createdById])
  @@index([createdAt])
  @@map("erp_stock_outs")
}

model StockOutItem {
  id          String   @id @default(uuid())
  stockOutId  String
  stockOut    StockOut @relation(fields: [stockOutId], references: [id], onDelete: Cascade)
  materialId  String
  material    Material @relation(fields: [materialId], references: [id])
  quantity    Decimal  @db.Decimal(10, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([stockOutId])
  @@index([materialId])
  @@map("erp_stock_out_items")
}

// ==================== ERP：盘点单（头 + 明细） ====================

model StockCheck {
  id          String           @id @default(uuid())
  batchNo     String           @unique
  warehouseId String
  warehouse   Warehouse        @relation(fields: [warehouseId], references: [id])
  checkDate   DateTime
  status      StockCheckStatus @default(DRAFT)
  remark      String?          @db.Text
  createdById String
  createdAt   DateTime         @default(now())

  items StockCheckItem[]

  @@index([warehouseId])
  @@index([status])
  @@index([checkDate])
  @@map("erp_stock_checks")
}

model StockCheckItem {
  id           String     @id @default(uuid())
  stockCheckId String
  stockCheck   StockCheck @relation(fields: [stockCheckId], references: [id], onDelete: Cascade)
  materialId   String
  material     Material   @relation(fields: [materialId], references: [id])
  bookQty      Decimal    @db.Decimal(10, 2)
  actualQty    Decimal?   @db.Decimal(10, 2)
  diffQty      Decimal?   @db.Decimal(10, 2)
  diffAmount   Decimal?   @db.Decimal(12, 2)
  reason       String?    @db.Text
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())

  @@index([stockCheckId])
  @@index([materialId])
  @@map("erp_stock_check_items")
}

// ==================== ERP：库存流水总账 ====================

model StockMovement {
  id          String            @id @default(uuid())
  warehouseId String
  warehouse   Warehouse         @relation(fields: [warehouseId], references: [id])
  materialId  String
  material    Material          @relation(fields: [materialId], references: [id])
  type        StockMovementType
  quantity    Decimal           @db.Decimal(10, 2)
  beforeQty   Decimal           @db.Decimal(10, 2)
  afterQty    Decimal           @db.Decimal(10, 2)
  refType     String
  refId       String
  remark      String?           @db.Text
  createdById String
  createdAt   DateTime          @default(now())

  @@index([warehouseId])
  @@index([materialId])
  @@index([type])
  @@index([refType, refId])
  @@index([createdAt])
  @@map("erp_stock_movements")
}

// ==================== ERP：BOM（第 2 期预留） ====================

model BomHeader {
  id        String   @id @default(uuid())
  productId String
  version   String   @default("v1.0")
  isActive  Boolean  @default(true)
  remark    String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items BomItem[]

  @@index([productId])
  @@map("erp_bom_headers")
}

model BomItem {
  id           String    @id @default(uuid())
  bomId        String
  bom          BomHeader @relation(fields: [bomId], references: [id], onDelete: Cascade)
  materialId   String
  material     Material  @relation(fields: [materialId], references: [id])
  quantity     Decimal   @db.Decimal(10, 2)
  level        Int       @default(1)
  parentItemId String?
  parentItem   BomItem?  @relation("BomItemTree", fields: [parentItemId], references: [id])
  children     BomItem[] @relation("BomItemTree")
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())

  @@index([bomId])
  @@index([materialId])
  @@index([parentItemId])
  @@map("erp_bom_items")
}
