# Copy this file to .env on the server and fill in real values there.
# Do not commit real passwords, tokens, API keys, or secrets.

DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"

NEXT_PUBLIC_AMAP_JS_KEY="replace-with-amap-js-key"
NEXT_PUBLIC_AMAP_SECURITY_CODE="replace-with-amap-security-code"
AMAP_WEB_SERVICE_KEY="replace-with-amap-web-service-key"

UPLOAD_DIR="./uploads"
START_MODE="standalone"
